PORT=5000
NODE_ENV=development
MONGO_URI=
TRUST_PROXY=0
CORS_ORIGIN=
REQUEST_BODY_LIMIT=10kb

# API Rate Limiting
API_RATE_LIMIT_MAX=200
API_RATE_LIMIT_WINDOW_MS=900000

# Auth Rate Limiting
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX=5
LOGIN_RATE_LIMIT_WINDOW_MS=900000
REGISTER_RATE_LIMIT_MAX=10
REGISTER_RATE_LIMIT_WINDOW_MS=3600000
FORGOT_PWD_RATE_LIMIT_MAX=3
FORGOT_PWD_RATE_LIMIT_WINDOW_MS=3600000
RESET_PWD_RATE_LIMIT_MAX=5
RESET_PWD_RATE_LIMIT_WINDOW_MS=900000
PASSWORD_RESET_EXPIRES_MIN=10

LOG_REQUESTS=0

# JWT — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_strong_random_secret_here
JWT_EXPIRE=30d

# Session — should be different from JWT_SECRET in production
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
SESSION_SECRET=your_strong_random_session_secret_here

FRONTEND_URL=http://localhost:5173

# Redis
REDIS_URL=redis://redis:6379

# GitHub OAuth
GITHUB_CLIENT_ID=your_client_id_here
GITHUB_CLIENT_SECRET=your_client_secret_here
GITHUB_CALLBACK_URL=http://localhost:5000/api/auth/github/callback

# OAuth one-time exchange code TTL in seconds (default 300 = 5 minutes)
OAUTH_CODE_TTL_S=300

# OAuth exchange endpoint rate limiting
OAUTH_EXCHANGE_RATE_LIMIT_MAX=5
OAUTH_EXCHANGE_RATE_LIMIT_WINDOW_MS=60000

# Cloudinary (coming soon)
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=